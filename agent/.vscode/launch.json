{
    "version": "0.2.0",
    "configurations": [
        {
            "type": "node",
            "request": "launch",
            "name": "Debug Marvin Agent",
            "skipFiles": [
                "<node_internals>/**"
            ],
            "program": "${workspaceFolder}/src/index.ts",
            "args": [
                "--character",
                "characters/marvin.character.json"
            ],
            "runtimeExecutable": "${env:NVM_DIR}/versions/node/v23.6.0/bin/node",
            "runtimeArgs": [
                "--loader",
                "ts-node/esm"
            ],
            "env": {
                "AWS_PROFILE": "remx-dev",
                "NODE_ENV": "development",
                "TS_NODE_PROJECT": "./tsconfig.json"
            },
            "outFiles": [
                "${workspaceFolder}/dist/**/*.js"
            ],
            "console": "integratedTerminal"
        }
    ]
}